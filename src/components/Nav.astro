---
export interface Props {
  lang: 'en' | 'ro';
}
const { lang } = Astro.props;

const t = {
  en: { rooms: 'Rooms', gallery: 'Gallery', contact: 'Contact', book: 'Book Now', toggle: 'RO' },
  ro: { rooms: 'Camere', gallery: 'Galerie', contact: 'Contact', book: 'Rezervă', toggle: 'EN' },
};

const links = lang === 'en'
  ? { rooms: '/rooms', gallery: '/gallery', contact: '/contact', toggle: '/ro' }
  : { rooms: '/ro/camere', gallery: '/ro/galerie', contact: '/ro/contact', toggle: '/' };

const tx = t[lang];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-stone-100 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href={lang === 'en' ? '/' : '/ro'} class="flex items-center">
      <img
        src="/images/logo.png"
        alt="The Frontier Hotel"
        class="h-12 w-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a href={links.rooms}   class="text-sm font-medium text-stone-600 hover:text-brand-500 transition-colors">{tx.rooms}</a>
      <a href={links.gallery} class="text-sm font-medium text-stone-600 hover:text-brand-500 transition-colors">{tx.gallery}</a>
      <a href={links.contact} class="text-sm font-medium text-stone-600 hover:text-brand-500 transition-colors">{tx.contact}</a>
      <a href={links.toggle}  class="text-xs font-semibold text-stone-400 hover:text-brand-500 transition-colors border border-stone-200 rounded px-2 py-1">{tx.toggle}</a>
      <a href="/book" class="bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
        {tx.book}
      </a>
    </div>

    <!-- Mobile: Book + Hamburger -->
    <div class="flex md:hidden items-center gap-3">
      <a href="/book" class="bg-brand-500 text-white text-xs font-semibold px-4 py-2 rounded-lg">{tx.book}</a>
      <button id="menu-btn" class="text-stone-600" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-stone-100 bg-white px-4 pb-4 pt-2 space-y-2">
    <a href={links.rooms}   class="block py-2 text-sm font-medium text-stone-700">{tx.rooms}</a>
    <a href={links.gallery} class="block py-2 text-sm font-medium text-stone-700">{tx.gallery}</a>
    <a href={links.contact} class="block py-2 text-sm font-medium text-stone-700">{tx.contact}</a>
    <a href={links.toggle}  class="block py-2 text-xs font-semibold text-stone-400">{tx.toggle}</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
