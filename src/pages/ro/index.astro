---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Bun venit" lang="ro" description="Frontier Hotel — Confort și eleganță în inima României.">
  <Nav lang="ro" />

  <!-- Hero -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-stone-900">
      <img src="/images/hero.webp" alt="Frontier Hotel" class="w-full h-full object-cover opacity-60" loading="eager" />
    </div>
    <div class="relative z-10 text-center text-white px-4 max-w-3xl mx-auto">
      <img
        src="/images/The-Frontier-Hotel-No-Stars-Version-WHITE-TEXT.webp"
        alt="The Frontier Hotel — Where East Meets West"
        class="mx-auto mb-8 h-40 sm:h-56 w-auto object-contain drop-shadow-2xl"
        loading="eager"
      />
      <p class="text-stone-200 text-lg sm:text-xl mb-10 max-w-xl mx-auto">
        Unde confortul se întâlnește cu ospitalitatea românească autentică.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/book" class="bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-lg text-base transition-colors">
          Rezervă acum
        </a>
        <a href="/ro/camere" class="border border-white text-white hover:bg-white hover:text-stone-900 font-semibold px-8 py-4 rounded-lg text-base transition-colors">
          Vezi camerele
        </a>
      </div>
    </div>
  </section>

  <!-- Highlights -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="font-heading text-4xl font-bold text-stone-800 mb-4">De ce Frontier Hotel?</h2>
      <div class="w-16 h-px bg-gold-400 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {[
        { icon: '🛏', title: 'Camere confortabile', desc: 'Dotări moderne combinate cu un decor cald și primitor pentru o ședere odihnitoare.' },
        { icon: '📍', title: 'Locație centrală', desc: 'Acces facil la atracții, restaurante și mijloace de transport.' },
        { icon: '⭐', title: 'Servicii personalizate', desc: 'Echipa noastră se asigură că fiecare oaspete se simte ca acasă.' },
      ].map(({ icon, title, desc }) => (
        <div class="text-center">
          <div class="text-4xl mb-4">{icon}</div>
          <h3 class="font-heading text-xl font-semibold text-stone-800 mb-2">{title}</h3>
          <p class="text-stone-500 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA banner -->
  <section class="bg-brand-500 py-20 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold text-white mb-4">Gata să rezervi?</h2>
      <p class="text-brand-100 mb-8 text-lg">Cel mai bun tarif garantat prin rezervare directă.</p>
      <a href="/book" class="inline-block bg-white text-brand-500 font-semibold px-10 py-4 rounded-lg hover:bg-stone-100 transition-colors text-base">
        Rezervă acum
      </a>
    </div>
  </section>

  <Footer lang="ro" />
</Base>
